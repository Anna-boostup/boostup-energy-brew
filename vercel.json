{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "github": {
    "enabled": false
  },
  "functions": {
    "api/send-email.ts": {
      "includeFiles": "public/**"
    }
  },
  "crons": [
    {
      "path": "/api/sync-packeta-status",
      "schedule": "0 16 * * *"
    }
  ]
}